# Frontend (Next.js) — variables d'environnement de DEV LOCAL
# Dupliquer en `.env.local` (jamais commite, deja dans .gitignore)
#
# En PROD via Docker : ce fichier n'est pas utilise. Le build du frontend
# recoit NEXT_PUBLIC_API_URL via le docker-compose.yml (build args), qui pointe
# vers https://api.${DOMAIN} (multi-origin).

# URL du backend FastAPI - UNIQUEMENT pour le dev local
# (lance avec `npm run dev` sans Docker, frontend sur :3000 + backend sur :8000)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Mode demo : "true" = donnees fictives, aucun appel reseau
# Utilise pour le deploiement Vercel preview public
NEXT_PUBLIC_DEMO=false

# Pseudo affiche dans les liens "boutique bonus" des TrackerCards
NEXT_PUBLIC_TRACKER_USERNAME=
