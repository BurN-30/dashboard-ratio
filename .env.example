# ============================================
# TrackBoard - Configuration
# ============================================
# Dupliquer en .env et remplir les valeurs

# --- DATABASE ---
DATABASE_URL=postgresql://trackboard:change_me@db:5432/trackboard
# Pour SQLite local (dev): sqlite:///./trackboard.db

# --- SECURITY ---
# Generer avec: openssl rand -hex 32
JWT_SECRET=change-this-to-a-very-long-random-string-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24

# Mot de passe admin dashboard
ADMIN_PASSWORD=change_me

# --- HARDWARE AGENT ---
# Token pour authentifier l'agent hardware (openssl rand -hex 16)
HW_AGENT_TOKEN=change_me_to_a_random_hex_string

# --- SCRAPER ---
# Intervalle entre les scrapes auto (s) — actuellement le scheduler tourne
# a heures fixes 8h/14h/20h Europe/Paris, cette variable est conservee pour usage futur
SCRAPE_INTERVAL=3600

# --- DOMAIN ---
# Domaine de base. Le reverse proxy host servira dash.${DOMAIN} (frontend) et
# api.${DOMAIN} (backend). Utilise pour CORS et build du frontend.
DOMAIN=example.com

# --- POSTGRES (Docker) ---
POSTGRES_USER=trackboard
POSTGRES_PASSWORD=change_me
POSTGRES_DB=trackboard

# --- TRACKERS CREDENTIALS ---
# Pseudo affiche dans le frontend (liens boutique bonus)
TRACKER_USERNAME=

# Sharewood
SW_USER=
SW_PASS=
SW_USERNAME=

# Generation-Free
GF_USER=
GF_PASS=
GF_USERNAME=

# TheOldSchool
TOS_USER=
TOS_PASS=
TOS_USERNAME=

# Torr9
TORR9_USER=
TORR9_PASS=
TORR9_USERNAME=

# Gemini Tracker
GEMINI_USER=
GEMINI_PASS=
GEMINI_USERNAME=

# --- MEDIA SERVICES (optionnels) ---
# Plex
MEDIA_PLEX_URL=
MEDIA_PLEX_TOKEN=

# Radarr
MEDIA_RADARR_URL=
MEDIA_RADARR_API_KEY=

# Sonarr
MEDIA_SONARR_URL=
MEDIA_SONARR_API_KEY=

# Tautulli
MEDIA_TAUTULLI_URL=
MEDIA_TAUTULLI_API_KEY=
