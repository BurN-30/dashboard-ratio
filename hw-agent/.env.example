# Hardware Agent - Configuration
# Dupliquer en .env (jamais commite)

# URL WebSocket du backend (route publique /hardware/ws/agent)
# Avec Caddy en same-origin sur le VPS, l'URL est sur le domaine principal :
WS_URL=wss://dashboard.example.com/hardware/ws/agent

# Token d'authentification (DOIT etre identique a HW_AGENT_TOKEN du .env serveur)
HW_AGENT_TOKEN=change_me_to_match_server

# Intervalle entre deux envois (secondes)
INTERVAL=2
